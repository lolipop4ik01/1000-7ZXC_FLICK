    DelayLabel.Font = Enum.Font.Jura
    DelayLabel.TextSize = 12
    DelayLabel.Parent = DelayFrame
    
    local DelaySlider = Instance.new("Frame")
    DelaySlider.Size = UDim2.new(1, 0, 0, 22)
    DelaySlider.Position = UDim2.new(0, 0, 0, 22)
    DelaySlider.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
    DelaySlider.Parent = DelayFrame
    Instance.new("UICorner", DelaySlider).CornerRadius = UDim.new(0, 10)
    
    local DelayFill = Instance.new("Frame")
    DelayFill.Size = UDim2.new(Config.ReturnDelay / 50, 0, 1, 0)
    DelayFill.BackgroundColor3 = Color3.fromRGB(255, 100, 100)
    DelayFill.Parent = DelaySlider
    Instance.new("UICorner", DelayFill).CornerRadius = UDim.new(0, 10)
    
    local delayDragging = false
    DelaySlider.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then delayDragging = true end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then delayDragging = false end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if delayDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local pos = math.clamp((input.Position.X - DelaySlider.AbsolutePosition.X) / DelaySlider.AbsoluteSize.X, 0, 1)
            DelayFill.Size = UDim2.new(pos, 0, 1, 0)
            local val = math.floor(pos * 50)
            DelayLabel.Text = "⏱️ RETURN DELAY: " .. val .. " ms"
            Config.ReturnDelay = val
            saveConfig()
        end
    end)
    
    -- Bind Button
    local BindButton = Instance.new("TextButton")
    BindButton.Size = UDim2.new(1, 0, 0, 35)
    BindButton.BackgroundColor3 = Color3.fromRGB(50, 50, 55)
    BindButton.TextColor3 = Color3.new(1, 1, 1)
    BindButton.Font = Enum.Font.Jura
    BindButton.TextSize = 14
    BindButton.Text = "⌨️ BIND: " .. Config.Keybind
    BindButton.Parent = Container
    Instance.new("UICorner", BindButton).CornerRadius = UDim.new(0, 6)
    
    getgenv().UpdateBindButtonText = function(key)
        pcall(function() BindButton.Text = "⌨️ BIND: " .. key end)
    end
    
    BindButton.MouseButton1Click:Connect(function()
        waitingForBind = true
        BindButton.Text = "⌨️ PRESS ANY KEY..."
        task.wait(3)
        if waitingForBind then
            waitingForBind = false
            BindButton.Text = "⌨️ BIND: " .. Config.Keybind
        end
    end)
    
    -- Hide GUI
    local HideButton = Instance.new("TextButton")
    HideButton.Size = UDim2.new(1, 0, 0, 35)
    HideButton.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
    HideButton.TextColor3 = Color3.new(1, 1, 1)
    HideButton.Font = Enum.Font.Jura
    HideButton.TextSize = 14
    HideButton.Text = "👁️ HIDE GUI"
    HideButton.Parent = Container
    Instance.new("UICorner", HideButton).CornerRadius = UDim.new(0, 6)
    HideButton.MouseButton1Click:Connect(function()
        MainFrame.Visible = false
        notify("GUI hidden. Click F button to show", 2)
    end)
    
    -- Kill GUI
    local KillButton = Instance.new("TextButton")
    KillButton.Size = UDim2.new(1, 0, 0, 35)
    KillButton.BackgroundColor3 = Color3.fromRGB(80, 40, 40)
    KillButton.TextColor3 = Color3.new(1, 1, 1)
    KillButton.Font = Enum.Font.Jura
    KillButton.TextSize = 14
    KillButton.Text = "💀 DESTROY GUI"
    KillButton.Parent = Container
    Instance.new("UICorner", KillButton).CornerRadius = UDim.new(0, 6)
    KillButton.MouseButton1Click:Connect(function()
        pcall(function() ScreenGui:Destroy() end)
        ScreenGui = nil
        MainFrame = nil
        CircleButton = nil
        notify("GUI destroyed. Re-execute script to restore", 2)
    end)
    
    CircleButton.MouseButton1Click:Connect(function()
        if MainFrame then MainFrame.Visible = not MainFrame.Visible end
    end)
end

-- ========== ИНИЦИАЛИЗАЦИЯ ==========
if getgenv().FlickLoaded then
    if getgenv().RestoreGUI then getgenv().RestoreGUI() end
else
    getgenv().FlickLoaded = true
    getgenv().FlickToMurderer = flickToMurderer
    getgenv().RestoreGUI = createGUI
    
    setupKeybind()
    createGUI()
    saveConfig()
    
    notify("⚡ FLICK TO MURDERER v6 LOADED ⚡\nReturn after LMB | Randomness: " .. Config.ReturnRandomness .. "% | Delay: " .. Config.ReturnDelay .. "ms", 3)
end

print("Flick To Murderer v6 loaded - Return ONLY after LMB click!")
