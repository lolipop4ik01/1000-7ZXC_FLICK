    -- НОВАЯ ЛОГИКА: мгновенный поворот
    if Config.InstantFlick then
        -- Вариант 1: Самый быстрый - прямая установка CFrame
        cam.CFrame = CFrame.lookAt(cam.CFrame.Position, targetPos)
    else
        -- Вариант 2: Ультрабыстрый с минимальной анимацией (для совместимости)
        local targetCFrame = CFrame.lookAt(oldCFrame.Position, targetPos)
        
        -- Увеличенная скорость: FlickSpeed * 10 * π (ранее было 0.5 * π)
        local currentLook = oldCFrame.LookVector
        local targetLook = (targetPos - oldCFrame.Position).Unit
        local dot = math.clamp(currentLook:Dot(targetLook), -1, 1)
        local angleDist = math.acos(dot)
        local angularSpeed = Config.FlickSpeed * 10 * math.pi
        local totalTime = math.max(angleDist / angularSpeed, 0.016)
        
        -- Всего 2 шага для минимальной задержки
        local steps = 2
        local waitTime = totalTime / steps
        
        for i = 1, steps do
            cam.CFrame = oldCFrame:Lerp(targetCFrame, i / steps)
            task.wait(waitTime)
        end
    end
    
    autoShoot(murderer)
end

-- ========== KEYBIND SYSTEM ==========
local waitingForBind = false

local function setupKeybind()
    local connection
    connection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        
        if waitingForBind then
            waitingForBind = false
            if input.KeyCode ~= Enum.KeyCode.Unknown then
                Config.Keybind = input.KeyCode.Name
                saveConfig()
                notify("Keybind set to: " .. Config.Keybind, 1)
                if getgenv().UpdateBindButtonText then
                    getgenv().UpdateBindButtonText(Config.Keybind)
                end
            end
            return
        end
        
        if input.KeyCode == Enum.KeyCode[Config.Keybind] then
            flickToMurderer()
        end
    end)
    
    getgenv().KeybindConnection = connection
end

